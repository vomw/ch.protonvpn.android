      "respectGitIgnore": false,
      "respectGeminiIgnore": false
    }
  },
  "tools": {
    "sandboxAllowedPaths": [],
    "sandboxNetworkAccess": false
  },
  "security": {
    "enablePermanentToolApproval": true
  },
  "experimental": {
    "worktrees": true,
    "directWebFetch": true
