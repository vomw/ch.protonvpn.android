{
  "general": {
    "defaultApprovalMode": "auto_edit",
    "enableAutoUpdate": false,
    "vimMode": false,
    "enableNotifications": true,
    "plan": {
      "directory": "",
      "modelRouting": false
    },
    "debugKeystrokeLogging": true
  },
  "ui": {
    "autoThemeSwitching": false,
    "inlineThinkingMode": "full",
    "showStatusInTitle": true,
